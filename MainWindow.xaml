<Window x:Class="Chatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chatbot"
        mc:Ignorable="d"
        Background="#DDEEFF"
        
        Title="Cyberbot Cybersecurity AI" Height="450" Width="800">

    <Window.Recources>
        <Style  x: Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="red"/>
            <Setter Property="Background" Value="white"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <!----Making the font family nice-->
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <!----Making a pointer hand icon when the user wants to click-->
            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True" >
                                <Setter Property="Background" Value="#2255AA"
                                        
                            </Trigger>



                        </ControlTemplate.Triggers>
                    </ControlTemplate>


                </Setter.Value>


            </Setter>

        </Style>
            
            
    </Window.Recources>

    <Grid>
        
        
        <!---- Home Grid
        
        Our UI will work with different grids (DETAILED IN THE VIDEO)-->

        <Grid x: Name="home_grid" Visibility="Visible" Margin="10, 25, 0, 25" HorizontalAlignment="Left" Width="900">
            <Grid.RowDefinitions>

                <RowDefenition height="Auto"/>
                <RowDefenition height="Auto"/>
                <RowDefenition height="Auto"/>
                <RowDefenition height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0"
                       FontFamily="Courier New"
                       FontSize="13"
              Foreground="#1A3A5C"
                       Margin="0,111,0,2"
                       xml:space="preserve" Grid.RowSpan="4" Text="&#xA;   ____      _               ____        _&#xA;  / ___|   _| |__   ___ _ __| __ )  ___ | |_&#xA; | |  | | | | '_ \ / _ \ '__|  _ \ / _ \| __|&#xA; | |__| |_| | |_) |  __/ |  | |_) | (_) | |_&#xA;  \____\__, |_.__/ \___|_|  |____/ \___/ \__|&#xA;       |___/&#xA;   Cybersecurity Awareness Bot&#xA;================================================"/>



            <TextBlock Grid.Row="1"
                         Text="Welcome to CyberBotAI"
                       FontFamily="Segoe UI light"
                       
                        FontSize="26"
                       Foreground="#557799"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,4"/>


            <TextBlock Grid.Row="3"
                         Text="Your cybersecurity companion"
                       FontFamily="Segoe UI light"
                       
                        FontSize="13"
                       Foreground="#557799"
                       HorizontalAlignment="left"
                       Margin="316,104,0,-77"/>


              <Button Grid.Row="3"
                       Content="Proceed"
                       Style="{StaticResource CyberButton}"
                       Height="44" Width="200"
                       HorizontalAlignment="Center"
                        Click="proceed" Margin="0,122,0,-122"
                      
                      
                     

        </Grid>
            
            
            
            
        
        
    </Grid>
    
</Window>
